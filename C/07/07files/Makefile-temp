# マクロ（定数）の定義
CC = gcc
CFLAGS = -Wall
.PHONY: all clean	# ダミーターゲットを明示的に指定

# makeの引数なしで生成するものの一覧
all: max-full max queen-full queen  #loopFuncP2 #loopFuncP1


# maxを生成するためのルール
max: max.o myfunc1.o myfunc2.o
	$(CC) $(CFLAGS) -o max max.o myfunc1.o myfunc2.o

max.o: max.c myfunc1.h myfunc2.h
	$(CC) $(CFLAGS) -c max.c

myfunc1.o: myfunc1.c myfunc1.h
	$(CC) $(CFLAGS) -c myfunc1.c

myfunc2.o: myfunc2.c myfunc2.h
	$(CC) $(CFLAGS) -c myfunc2.c


# queenを生成するためのルール（課題）















# コンパイルによってできるものを削除する
clean:
	rm -f *.o max-full max queen-full queen loopFuncP2

